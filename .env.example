# ============================================================
# YT Longform Studio — environment example
# Proyek ini KHUSUS video panjang (longform 16:9) dan upload YouTube saja.
# ============================================================

# Server / Dashboard lokal
PORT=3050
PUBLIC_BASE_URL=https://yt.emsa.pro
AUTO_DASHBOARD_PIN=123456

# OpenAI (naskah, gambar, TTS, transkripsi)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
STORY_MODEL=gpt-4.1-mini
IMAGE_MODEL=gpt-image-2
IMAGE_SIZE=1536x1024
IMAGE_QUALITY=low
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=cedar
OPENAI_TRANSCRIBE_MODEL=whisper-1

# ElevenLabs (opsional, alternatif TTS)
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_VOICE_ID=pFZP5JQG7iQjIQuC4Bku

# Pexels (B-roll stock videos)
PEXELS_API_KEY=
PEXELS_PREFER_VIDEO=true
PEXELS_MIN_DURATION_SEC=8
PEXELS_MAX_RESULTS=5

# Render
SPEECH_TEMPO=1.0
RENDER_TITLE_FONT=Bebas Neue
RENDER_BODY_FONT=Segoe UI Semibold
RENDER_MONO_FONT=Cascadia Code

# Otomatisasi longform
YT_TIME_ZONE=Asia/Bangkok
YT_DAILY_GENERATE_LIMIT=1
YT_DURATION_SEC=360
YT_SCENE_COUNT=14
YT_WORKFLOW_FILE=yt-longform-generate.yml
YT_STRICT_REMOTE=false

# Cost estimator
STORY_INPUT_USD_PER_1M_TOKENS=0.40
STORY_OUTPUT_USD_PER_1M_TOKENS=1.60
OPENAI_TTS_USD_PER_1M_CHARS=15
ELEVENLABS_TTS_USD_PER_1K_CHARS=0.10

# YouTube auto upload (token sama persis dengan akun banyaktau)
YOUTUBE_UPLOAD_ENABLED=true
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_PRIVACY_STATUS=public
YOUTUBE_CATEGORY_ID=27
YOUTUBE_TAGS=BanyakTau,Edukasi,Pengetahuan,Sains,Sejarah,Teknologi
# Thumbnail generation (false = skip AI thumbnail, buat manual)
THUMBNAIL_GENERATION_ENABLED=true

YOUTUBE_CUSTOM_THUMBNAIL_ENABLED=true
YOUTUBE_THUMBNAIL_UPLOAD_ATTEMPTS=1
YOUTUBE_DAILY_UPLOAD_LIMIT=2

# Auto-playlist: otomatis masukkan video ke playlist berdasarkan kategori
# Format: kategori:PLAYLIST_ID dipisah koma
# Contoh: sains:PLxxxxxxx,sejarah:PLyyyyyyy,teknologi:PLzzzzzzz
YOUTUBE_PLAYLISTS=
# Playlist default jika kategori tidak cocok (opsional)
YOUTUBE_DEFAULT_PLAYLIST_ID=

# YouTube Trending (data-driven topic selection)
# API key dari Google Cloud Console (YouTube Data API v3)
YOUTUBE_DATA_API_KEY=
YOUTUBE_TRENDING_ENABLED=true
YOUTUBE_TRENDING_REGION=ID

# Upload media ke hosting (folder TERPISAH dari banyaktau)
UPLOAD_DRIVER=sftp
SFTP_HOST=
SFTP_PORT=65002
SFTP_USER=
SFTP_PASSWORD=
SFTP_REMOTE_DIR=/home/USER/domains/emsa.pro/public_html/yt
SFTP_UPLOAD_TIMEOUT_SECONDS=300

FTP_HOST=
FTP_PORT=21
FTP_USER=
FTP_PASSWORD=
FTP_REMOTE_DIR=/public_html/yt
