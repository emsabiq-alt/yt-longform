{
  "framework": null,
  "buildCommand": null,
  "outputDirectory": "public",
  "functions": {
    "api/*.js": { "memory": 256, "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    }
  ]
}
